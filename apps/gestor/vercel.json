{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/v1/(.*)", "dest": "https://socialveiculos-api.fly.dev/v1/$1" },
    { "src": "/static/(.*)", "dest": "https://socialveiculos-api.fly.dev/static/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
