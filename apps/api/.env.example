# Social Veículos — API
# Copie para .env e preencha os valores.
# Em produção (api_debug=false) o boot FALHA se JWT_SECRET ou WEBHOOK_SECRET
# ainda estiverem com o valor placeholder — isso é proposital.

# ── Servidor ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Em produção use false (ativa as validações de segredo no boot).
API_DEBUG=true
APP_ENV=development
# Monitoramento de erros (opcional). Ex.: https://xxx@o0.ingest.sentry.io/0
# SENTRY_DSN=

# ── CORS / URLs públicas (Vercel) ──────────────────────────────
# Origens dos fronts, separadas por vírgula. Em produção use os domínios Vercel.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# URL pública da vitrine (usada no sitemap.xml, canonical e Open Graph).
VITRINE_BASE_URL=http://localhost:5174
# URL pública do gestor (B2B) — usada em links de e-mail (ex.: reset de senha).
GESTOR_BASE_URL=http://localhost:5173

# ── E-mail transacional (Resend) ───────────────────────────────
# Sem RESEND_API_KEY o sistema cai no modo log (imprime o link no console) — ok em dev.
# Em produção, criar chave em resend.com e verificar um domínio no EMAIL_FROM.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=Social Veículos <nao-responda@seudominio.com.br>

# ── Banco de dados ─────────────────────────────────────────────
# Dev: SQLite. Produção: PostgreSQL (Supabase — use a connection string do painel,
# formato: postgresql+asyncpg://USER:PASS@HOST:5432/postgres).
DATABASE_URL=sqlite:///./socialveiculos.db

# ── JWT (OBRIGATÓRIO trocar em produção) ───────────────────────
# O segredo deve ter no mínimo 32 bytes em produção (quando API_DEBUG=false).
# Gere com: openssl rand -hex 32
JWT_SECRET=troque-esta-chave-em-producao
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Pagamentos (OBRIGATÓRIO trocar em produção) ────────────────
# Segredo compartilhado com o gateway para validar webhooks (header X-Webhook-Secret).
# Com o placeholder abaixo, dá para forjar confirmação de pagamento — NUNCA use em prod.
WEBHOOK_SECRET=troque-webhook-secret-em-producao

# ── SSO — URLs base dos módulos premium ────────────────────────
MODULO_CONTRATOS_URL=http://localhost:5180
MODULO_SIMULADOR_URL=http://localhost:5181
MODULO_MARKETING_URL=http://localhost:5182

# ── Storage de mídia (Cloudflare R2, compatível S3) ────────────
# Sem estas chaves o upload cai em disco local (ok em dev, gap em produção).
# No R2: S3_ENDPOINT_URL = https://<accountid>.r2.cloudflarestorage.com
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET_NAME=socialveiculos
# S3_REGION=auto
# S3_PUBLIC_URL=https://midia.seudominio.com

# ── Chaves de IA (assistente/motor.py) ─────────────────────────
# Lidas via os.getenv. Sem elas o assistente degrada para resposta mock e
# pula transcrição (Whisper) e voz (ElevenLabs) — não quebra, mas não funciona de verdade.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=

# ── Seed inicial ───────────────────────────────────────────────
# Senha do owner criado pelo seed.py (default: admin123).
# OWNER_SENHA=

# ── Credenciais de Desenvolvimento (seed) ──────────────────────
#
# | Perfil            | Email                        | Senha      |
# |-------------------|------------------------------|------------|
# | Admin Plataforma  | victorbelocorreia@gmail.com  | admin123   |
# | Gestor Demo       | gestor@autopremium.com.br    | demo123    |
# | Vendedor Demo     | carlos@autopremium.com.br    | demo123    |
# | Cliente Vitrine   | vitrine@demo.com             | demo123    |
