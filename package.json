{
  "name": "socialveiculos",
  "private": true,
  "version": "0.0.1",
  "description": "Social Veículos — Plataforma SaaS para gestão de lojas de veículos + vitrine B2C",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" run dev",
    "dev:gestor": "pnpm --filter @sv/gestor run dev",
    "dev:vitrine": "pnpm --filter @sv/vitrine run dev",
    "dev:api": "pnpm --filter @sv/api run dev",
    "build": "pnpm --filter \"./apps/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint apps packages",
    "test": "pnpm -r run test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
